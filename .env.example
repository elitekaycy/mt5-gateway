# Backend - MT5
CUSTOM_USER=admin
PASSWORD=1234
VNC_DOMAIN=vnc.example.com
API_DOMAIN=api.example.com

# MT5 API Configuration
MT5_API_PORT=5001

# Swagger UI scheme configuration (default: http)
# Set to "https" for production deployments behind reverse proxy
SWAGGER_SCHEME=http

# MT5 Connection Settings
# Maximum attempts to reconnect to MT5 when connection is lost (default: 3)
MT5_RECONNECT_ATTEMPTS=3

# Base delay in seconds between reconnection attempts (uses exponential backoff, default: 1.0)
MT5_RECONNECT_BASE_DELAY=1.0

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Traefik
TRAEFIK_DOMAIN=traefik.example.com
TRAEFIK_USERNAME=admin
ACME_EMAIL=admin@example.com

# ── Headless broker login (optional) ────────────────────────────────────────
# Set these and the gateway logs into the broker on boot — no VNC. Leave
# MT5_LOGIN empty to keep the manual VNC flow + persisted-volume login.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Exness-MT5Trial9

# servers.dat (the broker directory) is required for headless login. Provide it
# one of three ways: mount it at /defaults/servers.dat, bake it into the image
# (defaults/servers.dat at build — private images only), or fetch from a private
# artifacts repo by setting the token below. Empty token = skip the fetch.
QKT_ARTIFACTS_TOKEN=
QKT_ARTIFACTS_REPO=elitekaycy/qkt-artifacts
QKT_ARTIFACTS_FILE=servers.dat